# ============================================================
# TEMPLATE ENVIRONMENT VARIABLES
# Salin file ini menjadi .env lalu isi nilainya
# JANGAN pernah commit file .env ke GitHub!
# ============================================================

# --- Pilih salah satu LLM provider ---

# Groq (gratis, cepat) → daftar di console.groq.com
GROQ_API_KEY=your-grok-api-key

# Google Gemini (gratis tier) → daftar di aistudio.google.com
GOOGLE_API_KEY=your-gemini-api-key

# OpenAI (berbayar)
# OPENAI_API_KEY=your_openai_api_key_here

# --- Konfigurasi RAG ---
CHUNK_SIZE=1000
CHUNK_OVERLAP=100
TOP_K=15

# --- Nama model (sesuaikan dengan provider) ---
# Contoh Groq: llama3-8b-8192 / mixtral-8x7b-32768
# Contoh Gemini: gemini-1.5-flash
# Contoh Ollama: llama3 / mistral
LLM_MODEL_NAME=llama-3.1-8b-instant
GEMINI_MODEL_NAME=gemini-3-flash-preview

# --- Path dokumen dan vector store ---
DATA_DIR=./data
VECTORSTORE_DIR=./vectorstore
